# Tastytrade MCP Server — non-secret configuration.
# Copy to .env and adjust. NEVER put secrets here — secrets live in the OS keyring
# (managed via `tastytrade-mcp secrets set`).

# Allow order-placing tools (execute_trade, close_position, adjust_order,
# manage_watchlist). Disabled by default so an autonomous agent cannot place
# real orders without an explicit opt-in.
ENABLE_LIVE_TRADING=false

# Operator override: when true, order tools ALWAYS run as a dry-run (validation
# only), even if the agent passes dry_run=false. Gives a "propose-only" mode —
# the agent can build and validate orders but can never submit a live trade.
FORCE_DRY_RUN=false

# Reserve a percentage of buying power that orders may never consume. The
# pre-flight check rejects any order that would leave projected buying power
# below this percent of current buying power. 0 = no buffer (only block orders
# that would go negative). Example: 20 keeps at least 20% of buying power free.
BUYING_POWER_BUFFER_PCT=0

# Account-wide deployment ceiling: the maximum percent of total buying power
# that may be deployed at once. Unlike the per-order buffer above, this is
# derived from LIVE account state (used vs. available derivative buying power),
# so it counts buying power consumed by existing positions — even ones this
# server didn't place — and is correct across restarts and multiple instances.
# 0 = disabled. Example: 50 means deployed buying power can never exceed 50% of
# total capacity (used + available).
ACCOUNT_DEPLOY_LIMIT_PCT=0

# Logging
TASTYTRADE_MCP_LOG_LEVEL=INFO

# --- HTTP transport (only used with `tastytrade-mcp --transport http`) ---
# Allowed CORS origin for browser-based MCP clients.
MCP_CORS_ORIGIN=http://localhost:3333
# Per-IP rate limit on MCP endpoints.
MCP_RATE_LIMIT=120/minute
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=7698
